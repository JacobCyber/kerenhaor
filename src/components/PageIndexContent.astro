---
import Section from "@/components/Section.astro";
import Container from "@/components/Container.astro";
import MainHeading from "@/components/MainHeading.astro";
import Button from "@/components/buttons/Button.astro";
import Video from "@/components/Video.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import InfoCards from "@/components/InfoCards.astro";
import Stats from "@/components/Stats.astro";
import ProgramCards from "@/components/ProgramCards.astro";
import Agenda from "@/components/Agenda.astro";
import Testimonials from "@/components/Testimonials.astro";
import FormNewsletter from "@/components/forms/FormNewsletter.astro";
import Faq from "@/components/Faq.astro";
import type { Locale } from "@/i18n";
import { t } from "@/i18n";

const { locale = "en" } = Astro.props as { locale: Locale };
const heroTitle = t(locale, "hero.title");
const heroSubtitle = t(locale, "hero.subtitle");
const heroDesc = t(locale, "hero.description");
const ctaPrimary = t(locale, "hero.ctaPrimary");
const ctaSecondary = t(locale, "hero.ctaSecondary");
const infoHeading = t(locale, "infoCards.heading");
const missionHeading = t(locale, "mission.heading");
const missionDesc = t(locale, "mission.description");
const programsHeading = t(locale, "programs.heading");
const programsDesc = t(locale, "programs.description");
const schedHeading = t(locale, "schedule.heading");
const schedDesc = t(locale, "schedule.description");
const testimonialHeading = t(locale, "testimonials.heading");
const newsletterHeading = t(locale, "newsletter.heading");
const newsletterDesc = t(locale, "newsletter.description");
const faqHeading = t(locale, "faq.heading");
const basePath = locale === "en" ? "" : "/he";
---

<Section class="relative">
	<Video
		class:list={"absolute inset-0 object-cover object-top w-full h-full z-0"}
		src="/8088625-hd_1280_720_30fps.mp4"
		autoplay
		muted
		loop
		playsinline
		overlay="bg-white/70 z-10"
	/>

	<Container class:list={"relative z-20"}>
		<MainHeading>
			<h1 class="text-5xl font-bold tracking-wide">{heroTitle}</h1>
			<p class="text-2xl font-fredoka text-brand-gold font-semibold">{heroSubtitle}</p>
			<p>{heroDesc}</p>

			<div class="flex flex-wrap gap-4 justify-center md:justify-start">
				<Button href={`${basePath}/contact`} variant="blue">{ctaPrimary}</Button>
				<Button href={`${basePath}/#about`} variant="green">{ctaSecondary}</Button>
			</div>
		</MainHeading>
	</Container>
</Section>

<Section>
	<Container>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{infoHeading}</h2>
		</SectionHeading>
		<InfoCards locale={locale} />
	</Container>
</Section>

<Section class:list={"bg-neutral-50"} id="about">
	<Container>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{missionHeading}</h2>
			<p>{missionDesc}</p>
		</SectionHeading>
		<Stats locale={locale} />
	</Container>
</Section>

<Section>
	<Container>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{programsHeading}</h2>
			<p>{programsDesc}</p>
		</SectionHeading>
		<ProgramCards locale={locale} />
	</Container>
</Section>

<Section>
	<Container>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{schedHeading}</h2>
			<p>{schedDesc}</p>
		</SectionHeading>
		<Agenda locale={locale} />
	</Container>
</Section>

<Section class:list={"bg-neutral-50"}>
	<Container>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{testimonialHeading}</h2>
		</SectionHeading>
		<Testimonials locale={locale} />
	</Container>
</Section>

<Section class:list={"bg-brand-blue text-white"}>
	<Container class:list={"lg:py-12"}>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{newsletterHeading}</h2>
			<p class="max-w-2xl mx-auto">{newsletterDesc}</p>
		</SectionHeading>
		<FormNewsletter locale={locale} />
	</Container>
</Section>

<Section class:list={"bg-neutral-50"}>
	<Container>
		<SectionHeading>
			<h2 class="text-4xl font-bold tracking-wide">{faqHeading}</h2>
		</SectionHeading>
		<Faq locale={locale} />
	</Container>
</Section>
