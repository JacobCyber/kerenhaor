---
import Button from "@/components/buttons/Button.astro";
import type { Locale } from "@/i18n";
import { t } from "@/i18n";

const { locale = "en" } = Astro.props as { locale: Locale };
const nameLabel = t(locale, "formContact.nameLabel");
const namePlaceholder = t(locale, "formContact.namePlaceholder");
const emailLabel = t(locale, "formContact.emailLabel");
const emailPlaceholder = t(locale, "formContact.emailPlaceholder");
const phoneLabel = t(locale, "formContact.phoneLabel");
const phonePlaceholder = t(locale, "formContact.phonePlaceholder");
const messageLabel = t(locale, "formContact.messageLabel");
const messagePlaceholder = t(locale, "formContact.messagePlaceholder");
const submit = t(locale, "formContact.submit");
---

<form class="flex flex-col gap-4" onsubmit="return false;">
	<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
		<div class="flex flex-col gap-1.5">
			<label class="text-sm font-bold">{nameLabel}</label>
			<input
				type="text"
				placeholder={namePlaceholder}
				class="rounded-lg border border-gray-200 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-blue/40"
			/>
		</div>
		<div class="flex flex-col gap-1.5">
			<label class="text-sm font-bold">{emailLabel}</label>
			<input
				type="email"
				placeholder={emailPlaceholder}
				class="rounded-lg border border-gray-200 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-blue/40"
			/>
		</div>
	</div>
	<div class="flex flex-col gap-1.5">
		<label class="text-sm font-bold">{phoneLabel}</label>
		<input
			type="tel"
			placeholder={phonePlaceholder}
			class="rounded-lg border border-gray-200 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-blue/40"
		/>
	</div>
	<div class="flex flex-col gap-1.5">
		<label class="text-sm font-bold">{messageLabel}</label>
		<textarea
			rows="5"
			placeholder={messagePlaceholder}
			class="rounded-lg border border-gray-200 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-blue/40 resize-none"
		></textarea>
	</div>
	<Button variant="blue" size="lg" class="w-full justify-center">{submit}</Button>
</form>
