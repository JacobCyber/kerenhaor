---
import LucideSend from "~icons/lucide/send";
import Button from "@/components/buttons/Button.astro";
import type { Locale } from "@/i18n";
import { t } from "@/i18n";

const { locale = "en" } = Astro.props as { locale: Locale };
const placeholder = t(locale, "formNewsletter.placeholder");
const subscribe = t(locale, "formNewsletter.subscribe");
---

<form action="#" class="max-w-xl mx-auto -mt-8">
	<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
		<input
			id="newsletter-email"
			type="email"
			placeholder={placeholder}
			class="bg-white text-brand-foreground w-full sm:w-auto px-4 py-3 rounded-2xl border border-neutral-300 focus:outline-none focus:ring-2 focus:ring-brand-blue"
		/>
		<Button type="submit" variant="yellow" class="text-brand-foreground">
			<LucideSend />
			{subscribe}
		</Button>
	</div>
</form>
