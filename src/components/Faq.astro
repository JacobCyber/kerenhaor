---
import FaqItem from "@/components/FaqItem.astro";
import type { Locale } from "@/i18n";
import { t } from "@/i18n";

const { locale = "en" } = Astro.props as { locale: Locale };

const faqs = [
	{
		question: t(locale, "faq.q1"),
		answer: t(locale, "faq.a1"),
	},
	{
		question: t(locale, "faq.q2"),
		answer: t(locale, "faq.a2"),
	},
	{
		question: t(locale, "faq.q3"),
		answer: t(locale, "faq.a3"),
	},
	{
		question: t(locale, "faq.q4"),
		answer: t(locale, "faq.a4"),
	},
	{
		question: t(locale, "faq.q5"),
		answer: t(locale, "faq.a5"),
	},
];
---

<dl class="space-y-4 max-w-3xl mx-auto">
	{faqs.map((faq, i) => <FaqItem id={`faq-${i}`} question={faq.question} answer={faq.answer} />)}
</dl>
