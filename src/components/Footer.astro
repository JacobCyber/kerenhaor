---
import MapPin from "~icons/heroicons/map-pin";
import Phone from "~icons/heroicons/phone";
import Mail from "~icons/heroicons/envelope";
import IconLogo from "@/assets/logo/logo.svg";
import { address, phone as phoneConfig, email as emailConfig, orgNumber } from "@/data/config";
import type { Locale } from "@/i18n";
import { t } from "@/i18n";

const { locale = "en" } = Astro.props as { locale: Locale };
const siteTitle = t(locale, "siteName");
const tagline = t(locale, "footer.tagline");
const contactUs = t(locale, "footer.contactUs");
const hours = t(locale, "footer.hours");
const hoursWeekdays = t(locale, "footer.hoursWeekdays");
const hoursWeekdayTime = t(locale, "footer.hoursWeekdayTime");
const hoursFriday = t(locale, "footer.hoursFriday");
const copyright = t(locale, "footer.copyright");
const basePath = locale === "en" ? "" : "/he";
---

<footer class="bg-brand-foreground text-white py-12 px-4">
	<div class="container">
		<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-8">
			<div class="lg:col-span-2">
				<a href={basePath || "/"} class="flex gap-x-4 items-center">
					<IconLogo class:list={"size-12"} />
					<span class="font-bold font-fredoka text-4xl">{siteTitle}</span>
				</a>
				<p class="font-body text-base mt-4">
					{tagline}
				</p>
			</div>
			<div class="space-y-3 lg:col-start-5">
				<h3 class="font-body font-bold text-lg">{contactUs}</h3>
				<div class="flex items-center gap-2 text-sm">
					<MapPin class="w-4 h-4" /> {address.street}, {address.city}
				</div>
				<div class="flex items-center gap-2 text-sm">
					<Phone class="w-4 h-4" />
					<a href={phoneConfig.href}>{phoneConfig.label}</a>
				</div>
				<div class="flex items-center gap-2 text-sm">
					<Mail class="w-4 h-4" />
					<a href={emailConfig.href}>{emailConfig.label}</a>
				</div>
				<div class="text-sm opacity-70 mt-2">
					עמותה {orgNumber}
				</div>
			</div>
			<div class="space-y-3">
				<h3 class="font-body font-bold text-lg">{hours}</h3>
				<p class="text-sm">{hoursWeekdays}</p>
				<p class="text-sm">{hoursWeekdayTime}</p>
				<p class="text-sm">{hoursFriday}</p>
			</div>
		</div>
		<div class="border-t border-primary-foreground/20 mt-8 pt-6 text-center text-sm opacity-60 font-body">
			© {new Date().getFullYear()} {siteTitle}. {copyright}
			<span class="block">
				<a
					href="https://kerenhaohr.org"
					class="font-bold"
					target="_blank"
					rel="noopener noreferrer">קרן האור — Keren HaOhr</a
				>
			</span>
		</div>
	</div>
</footer>
