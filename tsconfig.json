{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"strictNullChecks": true,
		"allowJs": true,
		"resolveJsonModule": true,
    "types": ["unplugin-icons/types/astro"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	}
}
